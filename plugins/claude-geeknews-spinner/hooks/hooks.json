{
  "description": "Refresh Claude Code spinner verbs with the latest GeekNews headlines.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/refresh.mjs"],
            "async": true,
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/refresh.mjs"],
            "async": true,
            "timeout": 15
          }
        ]
      }
    ]
  }
}
